{
  "expo": {
    "name": "Jungle Safari Zookeeper",
    "slug": "jungle-safari-zookeeper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.orbissystems.junglesafarizookeeper",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app uses the microphone to record daily animal observation logs."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      },
      "permissions": ["android.permission.RECORD_AUDIO"],
      "package": "com.orbissystems.junglesafarizookeeper"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-av"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "junglesafari"
  }
}
