{
  "expo": {
    "name": "Jungle Safari Zookeeper",
    "slug": "jungle-safari-zookeeper",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.orbissystems.junglesafarizookeeper",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app uses the microphone to record daily animal observation logs."
      }
    },
    "android": {
      "permissions": ["android.permission.RECORD_AUDIO"],
      "package": "com.orbissystems.junglesafarizookeeper"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-av"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "junglesafari"
  }
}
